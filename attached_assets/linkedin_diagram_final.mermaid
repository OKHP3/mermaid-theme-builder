flowchart TD

    subgraph IGNITION ["⚡ Ignition"]
        A["💡 Spark\nROI of pictures vs. words"]:::spark
        B["Hypothesis\nNot all pictures earn their words"]:::core
        C["Framework\nValue = Clarity × Universality ÷ Words to generate"]:::core
    end

    subgraph STRATEGY ["🧭 Strategy"]
        D{{"Does the framing\nactually hold up?"}}:::gate
        E["Sharpen it\nRefine the ratio metaphor"]:::revision
        F["✨ The Recursive Twist\nDiagram the post — inside the post"]:::insight
        G{{"Is this too clever?\nWill readers get it\nor roll their eyes?"}}:::gate
        H["Dial it back\nLead with utility, not cleverness"]:::revision
    end

    subgraph CRAFT ["✏️ Craft"]
        I["Choose Medium\nLinkedIn · 3,000 char max · images in post · code in comments"]:::core
        J["Choose Tool\nMermaid — LLM-native · free · portable · no design degree"]:::core
        K["Draft\nHook → Thesis → Diagram → Proof → CTA"]:::core
        L{{"Does the hook\nland?"}}:::gate
        M["Rewrite the open\nKill the clever · find the honest"]:::revision
    end

    subgraph PROOF ["📐 Proof"]
        N["✏️ Embed the Diagram\nThis post's own process = the example"]:::insight
        O{{"Happy path only?\nDoes it reflect\nreal ideation?"}}:::gate
        P["Rebuild\nAdd loops · forks · dead ends · honest wrong turns"]:::revision
    end

    subgraph SHIP ["🚀 Ship"]
        Q["Publish\nPost + diagram image + code screenshot + raw code in comments"]:::publish
        R{{"Did the visual land\nfaster than words alone?"}}:::gate
        S["✅ Thesis Confirmed\nThe picture earned its words"]:::success
        T["Iterate\nRefine diagram or reframe post · re-enter Craft"]:::revision
    end

    A --> B --> C --> D
    D -->|"holds up"| F
    D -->|"too abstract"| E
    E -.->|"try again"| C

    F --> G
    G -->|"earned it"| I
    G -->|"too cute"| H
    H -.->|"reframe"| F

    I --> J --> K --> L
    L -->|"lands"| N
    L -->|"too stiff"| M
    M -.->|"rewrite"| K

    N --> O
    O -->|"yes — ship it"| Q
    O -->|"no — too linear"| P
    P -.->|"rebuild"| N

    Q --> R
    R -->|"high multiplier"| S
    R -->|"missed"| T
    T -.->|"loop back"| K

    classDef spark fill:#4A90D9,stroke:#1a5fa8,color:#ffffff,font-weight:bold,stroke-width:2px
    classDef core fill:#F0F4F8,stroke:#9EB3C2,color:#2d3748,stroke-width:1.5px
    classDef gate fill:#FFF8E7,stroke:#D4A017,color:#4a3300,stroke-width:2px,font-style:italic
    classDef revision fill:#FDE8E8,stroke:#C0392B,color:#7b1a1a,stroke-width:1.5px
    classDef insight fill:#E8F5E9,stroke:#2E7D32,color:#1a3d1e,font-weight:bold,stroke-width:2px
    classDef publish fill:#6C5CE7,stroke:#4a3ab5,color:#ffffff,font-weight:bold,stroke-width:2px
    classDef success fill:#00B894,stroke:#007a61,color:#ffffff,font-weight:bold,stroke-width:2px

    style IGNITION fill:#EBF4FF,stroke:#4A90D9,stroke-width:1.5px,color:#1a3d5c
    style STRATEGY fill:#FFFBF0,stroke:#D4A017,stroke-width:1.5px,color:#4a3300
    style CRAFT fill:#F5F5F5,stroke:#9EB3C2,stroke-width:1.5px,color:#2d3748
    style PROOF fill:#F0FFF4,stroke:#2E7D32,stroke-width:1.5px,color:#1a3d1e
    style SHIP fill:#F3F0FF,stroke:#6C5CE7,stroke-width:1.5px,color:#2d1b6e

    linkStyle 4 stroke:#C0392B,stroke-width:2px,stroke-dasharray:6 4
    linkStyle 6 stroke:#2E7D32,stroke-width:2px
    linkStyle 7 stroke:#C0392B,stroke-width:2px
    linkStyle 8 stroke:#C0392B,stroke-width:2px,stroke-dasharray:6 4
    linkStyle 10 stroke:#2E7D32,stroke-width:2px
    linkStyle 11 stroke:#C0392B,stroke-width:2px
    linkStyle 12 stroke:#C0392B,stroke-width:2px,stroke-dasharray:6 4
    linkStyle 14 stroke:#2E7D32,stroke-width:2px
    linkStyle 15 stroke:#C0392B,stroke-width:2px
    linkStyle 16 stroke:#C0392B,stroke-width:2px,stroke-dasharray:6 4
    linkStyle 18 stroke:#2E7D32,stroke-width:2px
    linkStyle 19 stroke:#C0392B,stroke-width:2px
    linkStyle 20 stroke:#C0392B,stroke-width:2px,stroke-dasharray:6 4
