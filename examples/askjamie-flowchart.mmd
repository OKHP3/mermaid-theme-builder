%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#5b3a27", "primaryTextColor": "#f6f2ee", "primaryBorderColor": "#c46a2c", "lineColor": "#a06e28", "secondaryColor": "#676a2c", "tertiaryColor": "#e6a03c", "background": "#f6f2ee", "mainBkg": "#eff2f5", "nodeBorder": "#a06e28", "clusterBkg": "#f0ebe5", "titleColor": "#2a2320", "edgeLabelBackground": "#f6f2ee", "fontFamily": "DM Sans, system-ui, sans-serif"}}}%%
%% Theme: AskJamie
